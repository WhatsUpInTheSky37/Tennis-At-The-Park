generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid()) @db.VarChar(30)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at")

  profile             Profile?
  sessionsCreated     Session[]          @relation("SessionCreator")
  sessionParticipants SessionParticipant[]
  invitesSent         Invite[]           @relation("InviteSender")
  invitesReceived     Invite[]           @relation("InviteReceiver")
  challengesSent      Challenge[]        @relation("ChallengesSent")
  challengesReceived  Challenge[]        @relation("ChallengesReceived")
  messages            Message[]
  reportsFiled        Report[]           @relation("Reporter")
  reportsAgainst      Report[]           @relation("Reported")
  disputesOpened      Dispute[]
  rating              Rating?
  enforcement         Enforcement?

  @@map("users")
}

model Profile {
  userId       String   @id @map("user_id") @db.VarChar(30)
  displayName  String   @map("display_name") @db.VarChar(100)
  skillLevel   Float    @default(3.0) @map("skill_level")
  handedness   String   @default("right") @db.VarChar(20)
  bio          String   @default("") @db.Text
  lookingToPlay Boolean @default(false) @map("looking_to_play")
  availabilityJson Json? @map("availability_json")
  photoUrl     String?  @map("photo_url") @db.VarChar(500)
  preferredFormats Json  @default("[]") @map("preferred_formats")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("profiles")
}

model Location {
  id         String   @id @default(cuid()) @db.VarChar(30)
  name       String   @db.VarChar(100)
  lighted    Boolean
  courtCount Int      @map("court_count")
  sessions   Session[]
  matches    Match[]
  challenges Challenge[]

  @@map("locations")
}

model Session {
  id          String   @id @default(cuid()) @db.VarChar(30)
  createdBy   String   @map("created_by") @db.VarChar(30)
  locationId  String   @map("location_id") @db.VarChar(30)
  courtNumber Int?     @map("court_number")
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  format      String   @db.VarChar(50)
  stakes      String   @default("casual") @db.VarChar(50)
  levelMin    Float    @map("level_min")
  levelMax    Float    @map("level_max")
  notes       String   @default("") @db.Text
  status      String   @default("open") @db.VarChar(20)
  flexibleCourt Boolean @default(false) @map("flexible_court")
  createdAt   DateTime @default(now()) @map("created_at")

  creator      User                 @relation("SessionCreator", fields: [createdBy], references: [id])
  location     Location             @relation(fields: [locationId], references: [id])
  participants SessionParticipant[]
  invites      Invite[]
  messages     Message[]
  matches      Match[]

  @@index([locationId, startTime])
  @@index([status])
  @@map("sessions")
}

model SessionParticipant {
  sessionId String @map("session_id") @db.VarChar(30)
  userId    String @map("user_id") @db.VarChar(30)
  role      String @default("guest") @db.VarChar(20)
  status    String @default("confirmed") @db.VarChar(20)

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@id([sessionId, userId])
  @@map("session_participants")
}

model Invite {
  id        String   @id @default(cuid()) @db.VarChar(30)
  sessionId String   @map("session_id") @db.VarChar(30)
  fromUser  String   @map("from_user") @db.VarChar(30)
  toUser    String   @map("to_user") @db.VarChar(30)
  status    String   @default("pending") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])
  sender  User    @relation("InviteSender", fields: [fromUser], references: [id])
  receiver User   @relation("InviteReceiver", fields: [toUser], references: [id])

  @@map("invites")
}

model Message {
  id        String   @id @default(cuid()) @db.VarChar(30)
  sessionId String   @map("session_id") @db.VarChar(30)
  fromUser  String   @map("from_user") @db.VarChar(30)
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [fromUser], references: [id])
  reports Report[]

  @@index([sessionId])
  @@map("messages")
}

model Match {
  id               String   @id @default(cuid()) @db.VarChar(30)
  sessionId        String?  @map("session_id") @db.VarChar(30)
  playedAt         DateTime @map("played_at")
  locationId       String   @map("location_id") @db.VarChar(30)
  courtNumber      Int?     @map("court_number")
  format           String   @db.VarChar(50)
  teamsJson        Json     @map("teams_json")
  scoreJson        Json     @map("score_json")
  winnerUserIdsJson Json    @map("winner_user_ids_json")
  retiredFlag      Boolean  @default(false) @map("retired_flag")
  timeRanOutFlag   Boolean  @default(false) @map("time_ran_out_flag")
  notes            String   @default("") @db.Text
  status           String   @default("normal") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at")

  session    Session?    @relation(fields: [sessionId], references: [id])
  location   Location    @relation(fields: [locationId], references: [id])
  disputes   Dispute[]
  reports    Report[]
  challenges Challenge[]

  @@index([playedAt])
  @@map("matches")
}

model Dispute {
  id        String   @id @default(cuid()) @db.VarChar(30)
  matchId   String   @map("match_id") @db.VarChar(30)
  openedBy  String   @map("opened_by") @db.VarChar(30)
  reason    String   @db.VarChar(255)
  details   String   @db.Text
  status    String   @default("open") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  match    Match @relation(fields: [matchId], references: [id])
  opener   User  @relation(fields: [openedBy], references: [id])
  reports  Report[]

  @@map("disputes")
}

model Report {
  id             String   @id @default(cuid()) @db.VarChar(30)
  reporterUser   String   @map("reporter_user") @db.VarChar(30)
  reportedUser   String?  @map("reported_user") @db.VarChar(30)
  messageId      String?  @map("message_id") @db.VarChar(30)
  matchId        String?  @map("match_id") @db.VarChar(30)
  sessionId      String?  @map("session_id") @db.VarChar(30)
  disputeId      String?  @map("dispute_id") @db.VarChar(30)
  category       String   @db.VarChar(50)
  details        String   @db.Text
  status         String   @default("pending") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at")

  reporter User     @relation("Reporter", fields: [reporterUser], references: [id])
  reported User?    @relation("Reported", fields: [reportedUser], references: [id])
  message  Message? @relation(fields: [messageId], references: [id])
  match    Match?   @relation(fields: [matchId], references: [id])
  dispute  Dispute? @relation(fields: [disputeId], references: [id])

  @@map("reports")
}

model Rating {
  userId        String   @id @map("user_id") @db.VarChar(30)
  elo           Float    @default(1200)
  matchesPlayed Int      @default(0) @map("matches_played")
  wins          Int      @default(0)
  losses        Int      @default(0)
  currentStreak Int      @default(0) @map("current_streak")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("ratings")
}

model Enforcement {
  userId       String    @id @map("user_id") @db.VarChar(30)
  warningCount Int       @default(0) @map("warning_count")
  cooldownUntil DateTime? @map("cooldown_until")
  suspended    Boolean   @default(false)
  notes        String    @default("") @db.Text

  user User @relation(fields: [userId], references: [id])

  @@map("enforcement")
}

model Challenge {
  id              String   @id @default(cuid()) @db.VarChar(30)
  challengerId    String   @map("challenger_id") @db.VarChar(30)
  challengedId    String   @map("challenged_id") @db.VarChar(30)
  locationId      String   @map("location_id") @db.VarChar(30)
  proposedTime    DateTime @map("proposed_time")
  proposedEndTime DateTime @map("proposed_end_time")
  format          String   @db.VarChar(50)
  stakes          String   @default("casual") @db.VarChar(50)
  message         String   @default("") @db.Text
  status          String   @default("pending") @db.VarChar(20)
  declineReason   String   @default("") @db.Text @map("decline_reason")
  matchId         String?  @map("match_id") @db.VarChar(30)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  challenger User     @relation("ChallengesSent", fields: [challengerId], references: [id])
  challenged User     @relation("ChallengesReceived", fields: [challengedId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])
  match      Match?   @relation(fields: [matchId], references: [id])

  @@index([challengerId])
  @@index([challengedId])
  @@index([status])
  @@map("challenges")
}
