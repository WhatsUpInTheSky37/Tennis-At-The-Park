generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  isAdmin      Boolean  @default(false) @map("is_admin")
  lastActive   DateTime? @map("last_active")
  createdAt    DateTime @default(now()) @map("created_at")

  profile             Profile?
  sessionsCreated     Session[]          @relation("SessionCreator")
  sessionParticipants SessionParticipant[]
  invitesSent         Invite[]           @relation("InviteSender")
  invitesReceived     Invite[]           @relation("InviteReceiver")
  challengesSent      Challenge[]        @relation("ChallengesSent")
  challengesReceived  Challenge[]        @relation("ChallengesReceived")
  messages            Message[]
  reportsFiled        Report[]           @relation("Reporter")
  reportsAgainst      Report[]           @relation("Reported")
  disputesOpened      Dispute[]
  rating              Rating?
  enforcement         Enforcement?
  forumPosts          ForumPost[]
  forumReplies        ForumReply[]
  forumReactions      ForumReaction[]
  articleReactions    ArticleReaction[]
  notifications       Notification[]     @relation("NotificationsReceived")
  notificationsSent   Notification[]     @relation("NotificationsSent")
  articles            Article[]          @relation("ArticleAuthor")
  dmsSent             DirectMessage[]    @relation("DmSender")
  dmsReceived         DirectMessage[]    @relation("DmReceiver")

  @@map("users")
}

model Profile {
  userId       String   @id @map("user_id")
  displayName  String   @map("display_name")
  skillLevel   Float    @default(3.0) @map("skill_level")
  handedness   String   @default("right")
  bio          String   @default("")
  lookingToPlay Boolean @default(false) @map("looking_to_play")
  availabilityJson Json? @map("availability_json")
  photoUrl     String?  @map("photo_url")
  preferredFormats String[] @map("preferred_formats")
  yearsPlaying Int?     @map("years_playing")
  favoritePro  String?  @map("favorite_pro")
  phone        String?  @map("phone")
  okToText     Boolean  @default(false) @map("ok_to_text")
  isInstructor Boolean  @default(false) @map("is_instructor")
  acceptingClients Boolean @default(false) @map("accepting_clients")
  availability String[] @default([]) @map("availability_times")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("profiles")
}

model Location {
  id         String   @id @default(cuid())
  name       String
  lighted    Boolean
  courtCount Int      @map("court_count")
  sessions   Session[]
  matches    Match[]
  challenges Challenge[]

  @@map("locations")
}

model Session {
  id          String   @id @default(cuid())
  createdBy   String   @map("created_by")
  locationId  String   @map("location_id")
  courtNumber Int?     @map("court_number")
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  format      String
  stakes      String   @default("casual")
  levelMin    Float    @map("level_min")
  levelMax    Float    @map("level_max")
  notes       String   @default("")
  status      String   @default("open")
  flexibleCourt Boolean @default(false) @map("flexible_court")
  createdAt   DateTime @default(now()) @map("created_at")

  creator      User                 @relation("SessionCreator", fields: [createdBy], references: [id])
  location     Location             @relation(fields: [locationId], references: [id])
  participants SessionParticipant[]
  invites      Invite[]
  messages     Message[]
  matches      Match[]

  @@index([locationId, startTime])
  @@index([status])
  @@map("sessions")
}

model SessionParticipant {
  sessionId String @map("session_id")
  userId    String @map("user_id")
  role      String @default("guest")
  status    String @default("confirmed")

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@id([sessionId, userId])
  @@map("session_participants")
}

model Invite {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  fromUser  String   @map("from_user")
  toUser    String   @map("to_user")
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])
  sender  User    @relation("InviteSender", fields: [fromUser], references: [id])
  receiver User   @relation("InviteReceiver", fields: [toUser], references: [id])

  @@map("invites")
}

model Message {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  fromUser  String   @map("from_user")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [fromUser], references: [id])
  reports Report[]

  @@index([sessionId])
  @@map("messages")
}

model Match {
  id               String   @id @default(cuid())
  sessionId        String?  @map("session_id")
  playedAt         DateTime @map("played_at")
  locationId       String   @map("location_id")
  courtNumber      Int?     @map("court_number")
  format           String
  teamsJson        Json     @map("teams_json")
  scoreJson        Json     @map("score_json")
  winnerUserIdsJson Json    @map("winner_user_ids_json")
  retiredFlag      Boolean  @default(false) @map("retired_flag")
  timeRanOutFlag   Boolean  @default(false) @map("time_ran_out_flag")
  notes            String   @default("")
  status           String   @default("normal")
  createdAt        DateTime @default(now()) @map("created_at")

  session    Session?    @relation(fields: [sessionId], references: [id])
  location   Location    @relation(fields: [locationId], references: [id])
  disputes   Dispute[]
  reports    Report[]
  challenges Challenge[]

  @@index([playedAt])
  @@map("matches")
}

model Dispute {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  openedBy  String   @map("opened_by")
  reason    String
  details   String
  status    String   @default("open")
  createdAt DateTime @default(now()) @map("created_at")

  match    Match @relation(fields: [matchId], references: [id])
  opener   User  @relation(fields: [openedBy], references: [id])
  reports  Report[]

  @@map("disputes")
}

model Report {
  id             String   @id @default(cuid())
  reporterUser   String   @map("reporter_user")
  reportedUser   String?  @map("reported_user")
  messageId      String?  @map("message_id")
  matchId        String?  @map("match_id")
  sessionId      String?  @map("session_id")
  disputeId      String?  @map("dispute_id")
  forumPostId    String?  @map("forum_post_id")
  forumReplyId   String?  @map("forum_reply_id")
  category       String
  details        String
  status         String   @default("pending")
  createdAt      DateTime @default(now()) @map("created_at")

  reporter   User        @relation("Reporter", fields: [reporterUser], references: [id])
  reported   User?       @relation("Reported", fields: [reportedUser], references: [id])
  message    Message?    @relation(fields: [messageId], references: [id])
  match      Match?      @relation(fields: [matchId], references: [id])
  dispute    Dispute?    @relation(fields: [disputeId], references: [id])
  forumPost  ForumPost?  @relation(fields: [forumPostId], references: [id])
  forumReply ForumReply? @relation(fields: [forumReplyId], references: [id])

  @@map("reports")
}

model Rating {
  userId        String   @id @map("user_id")
  elo           Float    @default(1200)
  matchesPlayed Int      @default(0) @map("matches_played")
  wins          Int      @default(0)
  losses        Int      @default(0)
  currentStreak Int      @default(0) @map("current_streak")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("ratings")
}

model Enforcement {
  userId       String    @id @map("user_id")
  warningCount Int       @default(0) @map("warning_count")
  cooldownUntil DateTime? @map("cooldown_until")
  suspended    Boolean   @default(false)
  notes        String    @default("")

  user User @relation(fields: [userId], references: [id])

  @@map("enforcement")
}

model Challenge {
  id              String   @id @default(cuid())
  challengerId    String   @map("challenger_id")
  challengedId    String   @map("challenged_id")
  locationId      String   @map("location_id")
  proposedTime    DateTime @map("proposed_time")
  proposedEndTime DateTime @map("proposed_end_time")
  format          String
  stakes          String   @default("casual")
  message         String   @default("")
  status          String   @default("pending")
  declineReason   String   @default("") @map("decline_reason")
  matchId         String?  @map("match_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  challenger User     @relation("ChallengesSent", fields: [challengerId], references: [id])
  challenged User     @relation("ChallengesReceived", fields: [challengedId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])
  match      Match?   @relation(fields: [matchId], references: [id])

  @@index([challengerId])
  @@index([challengedId])
  @@index([status])
  @@map("challenges")
}

model ForumPost {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  categoryId String?   @map("category_id")
  subject    String
  body       String
  pinned     Boolean   @default(false)
  editedAt   DateTime? @map("edited_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  author        User            @relation(fields: [userId], references: [id])
  category      ForumCategory?  @relation(fields: [categoryId], references: [id])
  replies       ForumReply[]
  reactions     ForumReaction[]
  notifications Notification[]
  reports       Report[]

  @@index([createdAt])
  @@index([pinned, createdAt])
  @@index([categoryId])
  @@map("forum_posts")
}

model ForumReply {
  id        String    @id @default(cuid())
  postId    String    @map("post_id")
  userId    String    @map("user_id")
  body      String
  editedAt  DateTime? @map("edited_at")
  createdAt DateTime  @default(now()) @map("created_at")

  post          ForumPost       @relation(fields: [postId], references: [id])
  author        User            @relation(fields: [userId], references: [id])
  reactions     ForumReaction[]
  notifications Notification[]
  reports       Report[]

  @@index([postId])
  @@map("forum_replies")
}

model ForumCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  emoji     String   @default("")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  posts ForumPost[]

  @@map("forum_categories")
}

model ForumReaction {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String?  @map("post_id")
  replyId   String?  @map("reply_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  user  User        @relation(fields: [userId], references: [id])
  post  ForumPost?  @relation(fields: [postId], references: [id])
  reply ForumReply? @relation(fields: [replyId], references: [id])

  @@unique([userId, postId, emoji])
  @@unique([userId, replyId, emoji])
  @@index([postId])
  @@index([replyId])
  @@map("forum_reactions")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  fromUserId String?  @map("from_user_id")
  type       String
  postId     String?  @map("post_id")
  replyId    String?  @map("reply_id")
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  user     User        @relation("NotificationsReceived", fields: [userId], references: [id])
  fromUser User?       @relation("NotificationsSent", fields: [fromUserId], references: [id])
  post     ForumPost?  @relation(fields: [postId], references: [id])
  reply    ForumReply? @relation(fields: [replyId], references: [id])

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model Article {
  id          String    @id @default(cuid())
  authorId    String    @map("author_id")
  slug        String    @unique
  title       String
  excerpt     String    @default("")
  body        String
  coverImage  String?   @map("cover_image")
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  author    User              @relation("ArticleAuthor", fields: [authorId], references: [id])
  reactions ArticleReaction[]

  @@index([published, publishedAt])
  @@map("articles")
}

model ArticleReaction {
  id        String   @id @default(cuid())
  articleId String   @map("article_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([userId, articleId, emoji])
  @@index([articleId])
  @@map("article_reactions")
}

model DirectMessage {
  id        String   @id @default(cuid())
  fromId    String   @map("from_id")
  toId      String   @map("to_id")
  subject   String   @default("")
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  sender   User @relation("DmSender", fields: [fromId], references: [id])
  receiver User @relation("DmReceiver", fields: [toId], references: [id])

  @@index([toId, read])
  @@index([fromId])
  @@index([createdAt])
  @@map("direct_messages")
}
